APP_NAME=Petshop
APP_URL=http://localhost:8080
APP_ENV=local
APP_DEBUG=true

DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=petshop
DB_USERNAME=root
DB_PASSWORD=

SESSION_LIFETIME=120
PASSWORD_RESET_EXPIRY=60

# Geocoding (Nominatim — wajib User-Agent unik untuk production)
GEOCODING_USER_AGENT=PetshopApp/1.0 (local dev)
GEOCODING_TIMEOUT=5

# Pengaturan bisnis (default instalasi — dapat diubah owner lewat /admin/pengaturan)
PETSHOP_LAT=-6.2088
PETSHOP_LNG=106.8456
PICKUP_FREE_RADIUS_KM=3
PICKUP_EXTRA_FEE_PER_KM=5000

# Pembayaran manual (transfer bank)
PAYMENT_DEADLINE_HOURS=24
PETSHOP_BANK_NAME=BCA
PETSHOP_BANK_ACCOUNT=1234567890
PETSHOP_BANK_ACCOUNT_NAME=Petshop Sejahtera

# Promo penitipan (pet hotel)
PROMO_MIN_DAYS=7
PROMO_DISCOUNT_PERCENT=10
MIN_VACCINATION_COUNT=1

# Hubungi kami (WhatsApp — refund manual & bantuan)
PETSHOP_WHATSAPP=6281234567890
