APP_NAME=Petshop
APP_URL=http://localhost:8080
APP_ENV=production
APP_DEBUG=false

# Port host untuk docker compose
APP_PORT=8080

# MariaDB — dari host pakai localhost:DB_PORT; dari container app pakai service mariadb:3306
DB_HOST=127.0.0.1
DB_PORT=3307
DB_DATABASE=petshop
DB_USERNAME=root
DB_PASSWORD=root

SESSION_LIFETIME=120
PASSWORD_RESET_EXPIRY=60

GEOCODING_USER_AGENT=PetshopApp/1.0 (production)
GEOCODING_TIMEOUT=5

# Pengaturan bisnis (default instalasi — owner ubah lewat /admin/pengaturan)
PETSHOP_LAT=-6.2088
PETSHOP_LNG=106.8456
PICKUP_FREE_RADIUS_KM=3
PICKUP_EXTRA_FEE_PER_KM=5000

PAYMENT_DEADLINE_HOURS=24
PETSHOP_BANK_NAME=BCA
PETSHOP_BANK_ACCOUNT=1234567890
PETSHOP_BANK_ACCOUNT_NAME=Petshop Sejahtera

PROMO_MIN_DAYS=7
PROMO_DISCOUNT_PERCENT=10
MIN_VACCINATION_COUNT=1
PETSHOP_WHATSAPP=6281234567890
